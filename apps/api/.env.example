# ── AutoCut AI — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values before starting the server.
# Never commit .env to source control.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="AutoCut AI"
DEBUG=false

# IMPORTANT: Generate a strong random secret before deploying to production.
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — great for development and single-server deployments)
DATABASE_URL=sqlite+aiosqlite:///./autocut.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://autocut:password@localhost:5432/autocut

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=storage/uploads
OUTPUT_DIR=storage/output
THUMBNAIL_DIR=storage/thumbnails
MAX_UPLOAD_SIZE_MB=500

# ── CORS Origins (comma-separated) ───────────────────────────────────────────
# Add your production domains here
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8081","https://viditai.com","exp://localhost:8081"]

# ── FFmpeg ────────────────────────────────────────────────────────────────────
# Set to the full path if ffmpeg is not on your system PATH
FFMPEG_PATH=ffmpeg

# ── Processing Limits ─────────────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=4
JOB_TIMEOUT_SECONDS=600

# ── Auth ──────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days
JWT_ALGORITHM=HS256

# ── Plan Limits ───────────────────────────────────────────────────────────────
FREE_MONTHLY_EXPORTS=5
FREE_MAX_VIDEO_MINUTES=10

# ── Optional AI Features ──────────────────────────────────────────────────────
# Uncomment and configure after installing openai-whisper
# WHISPER_MODEL_SIZE=base

# ── Stripe (future payments) ─────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_BUSINESS_PRICE_ID=price_...
